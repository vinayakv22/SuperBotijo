# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js build output
.next/
out/

# Testing
coverage/
.nyc_output/
e2e-results/
playwright-report/
test-results/

# Environment files (should be provided at runtime)
.env
.env.local
.env.*.local

# Data files (will be mounted as volumes)
data/*.json
data/*.db
data/*.db-shm
data/*.db-wal

# Git
.git/
.gitignore
.gitattributes

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Documentation (not needed in runtime image)
*.md
!README.md
docs/
design-system/

# CI/CD
.github/
.gitlab-ci.yml

# Temporary files
tmp/
temp/
*.tmp

# Logs
logs/
*.log

# Playwright
playwright.config.ts
e2e/

# Build artifacts
dist/
build/

# TypeScript
*.tsbuildinfo

# Vitest
vitest.config.ts

# Docker files (no need to include in image)
Dockerfile*
docker-compose*.yml
.dockerignore

# Scripts that are for development only
scripts/
